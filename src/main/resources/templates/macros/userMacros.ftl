<#macro userMac user>
    <p><strong>Id: ${user.id}</strong></p>
    <p><strong>First name: ${user.firstName}</strong></p>
    <p><strong>Last name: ${user.lastName}</strong></p>
    <p><strong>Age: ${user.age}</strong></p>
    <p><strong>Email: ${user.email}</strong></p>
    <p><strong>Created: ${user.created}</strong></p>
    <p><strong>Updated: ${user.updated}</strong></p>
</#macro>